# Configuration d'environnement (copier en .env en production)

# Mode
ENVIRONMENT=production  # development, staging, production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_SECRET_KEY=change_me_in_production

# Database (SQLite)
DB_PATH=data/processed/predictions.db
AUDIT_DB_PATH=data/processed/audit.db

# Modèle ML
MODEL_VERSION=v2
MODEL_PATH=models/ensemble_model.pkl
PIC_CLASSIFIER_PATH=models/pic_classifier.pkl
BASELINE_MAPE=20.0

# Sécurité
RATE_LIMIT_PREDICT=100  # requêtes par minute
RATE_LIMIT_API=1000     # requêtes par heure
RATE_LIMIT_ADMIN=50     # requêtes par heure

# Admin (changer la clé!)
ADMIN_API_KEY=admin_secret_key

# Monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL_HOURS=24

# Météo
ENABLE_WEATHER=true
WEATHER_API=open-meteo
WEATHER_CACHE_PATH=data/processed/meteo_cache.csv

# Notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# ALERT_EMAIL=admin@example.com

# Logs
LOG_LEVEL=INFO
LOG_PATH=logs/app.log

# CORS
CORS_ORIGINS=*

# Debug
DEBUG=false
